// state.ts
var GPIO_PIN_LOW = 0;
var GPIO_PIN_HIGH = 1;
var gpioState = {
  [0 /* DISPLAY */]: GPIO_PIN_LOW,
  // GP0 - Display
  [1 /* SOIL_SENSOR */]: GPIO_PIN_LOW,
  // GP1 - Soil sensor
  [2 /* PUMP */]: GPIO_PIN_LOW,
  // GP2 - Pump
  [3 /* BUTTON */]: GPIO_PIN_HIGH
  // GP3 - Button (default HIGH with pull-up)
};
var state = {
  Module: null,
  isRunning: false,
  intervalId: null,
  tickCount: 0,
  currentDisplayValue: 0,
  soilDry: false
};

// logging.ts
var MAX_LOG_ENTRIES = 200;
var LOG_ELEMENT_ID = "log";
function getFilterId(type) {
  const parts = type.split("-");
  const camelCase = parts.map((part) => part.charAt(0).toUpperCase() + part.slice(1).toLowerCase()).join("");
  return `filter${camelCase}`;
}
function isLogLevelEnabled(type) {
  const filterId = getFilterId(type);
  const filterCheckbox = document.getElementById(filterId);
  if (!filterCheckbox) {
    return true;
  }
  return filterCheckbox.checked;
}
function getLogElement() {
  return document.getElementById(LOG_ELEMENT_ID);
}
function getTimestamp() {
  return (/* @__PURE__ */ new Date()).toLocaleTimeString();
}
function trimOldEntries(logElement) {
  while (logElement.children.length > MAX_LOG_ENTRIES) {
    const firstChild = logElement.firstChild;
    if (firstChild) {
      logElement.removeChild(firstChild);
    }
  }
}
function addLog2(message, type = "info") {
  if (!isLogLevelEnabled(type)) {
    return;
  }
  const log = getLogElement();
  if (!log) {
    console.warn("[LOGGING] Log element not found, message:", message);
    return;
  }
  const entry = document.createElement("div");
  entry.className = `log-entry ${type}`;
  entry.textContent = `[${getTimestamp()}] ${message}`;
  log.appendChild(entry);
  log.scrollTop = log.scrollHeight;
  trimOldEntries(log);
}
function clearLog() {
  const log = getLogElement();
  if (log) {
    log.innerHTML = "";
  }
  addLog2("Log cleared", "info");
}

// ui.ts
var TICK_DURATION_SECONDS = 0.02;
var SECONDS_PER_MINUTE = 60;
var SECONDS_PER_HOUR = 3600;
var MAX_DISPLAY_VALUE = 10;
var DOM_IDS = {
  SEVEN_SEGMENT: "sevenSegment",
  TICK_COUNT: "tickCount",
  RUNTIME: "runtime",
  SPEED_SLIDER: "speedSlider",
  SPEED_DISPLAY: "speedDisplay",
  START_STOP_BUTTON: "btnStartStop",
  LOG: "log",
  BUTTON_PRESS: "btnPress"
};
function getElement(id) {
  return document.getElementById(id);
}
function setElementText(id, text) {
  const element = getElement(id);
  if (element) {
    element.textContent = text;
    return true;
  }
  return false;
}
function calculateRuntime(tickCount) {
  const totalSeconds = Math.floor(tickCount * TICK_DURATION_SECONDS);
  const hours = Math.floor(totalSeconds / SECONDS_PER_HOUR);
  const minutes = Math.floor(totalSeconds % SECONDS_PER_HOUR / SECONDS_PER_MINUTE);
  const seconds = totalSeconds % SECONDS_PER_MINUTE;
  let formatted;
  if (hours > 0) {
    formatted = `${hours}h ${minutes}m`;
  } else if (minutes > 0) {
    formatted = `${minutes}m ${seconds}s`;
  } else {
    formatted = `${seconds}s`;
  }
  return { hours, minutes, seconds, formatted };
}
function updateSevenSegment() {
  state.currentDisplayValue = state.currentDisplayValue % MAX_DISPLAY_VALUE;
  setElementText(DOM_IDS.SEVEN_SEGMENT, String(state.currentDisplayValue));
}
function updateStatus() {
  setElementText(DOM_IDS.TICK_COUNT, state.tickCount.toLocaleString());
  const runtime = calculateRuntime(state.tickCount);
  setElementText(DOM_IDS.RUNTIME, runtime.formatted);
}

// gpio.ts
var VALID_GPIO_PINS = /* @__PURE__ */ new Set([
  0 /* DISPLAY */,
  1 /* SOIL_SENSOR */,
  2 /* PUMP */,
  3 /* BUTTON */
]);
function isValidPin(pin) {
  return VALID_GPIO_PINS.has(pin);
}
function toPinLevel(value) {
  return value !== 0 ? GPIO_PIN_HIGH : GPIO_PIN_LOW;
}
function getGPIOState(pin) {
  if (!isValidPin(pin)) {
    console.error(`[GPIO] Invalid pin number: ${pin}`);
    return GPIO_PIN_LOW;
  }
  return gpioState[pin];
}
function setGPIOState(pin, pinState) {
  if (!isValidPin(pin)) {
    console.error(`[GPIO] Invalid pin number: ${pin}`);
    return;
  }
  const previousState = gpioState[pin];
  const newState = toPinLevel(pinState);
  gpioState[pin] = newState;
  if (pin === 0 /* DISPLAY */ && previousState === GPIO_PIN_LOW && newState === GPIO_PIN_HIGH) {
    state.currentDisplayValue++;
    updateSevenSegment();
  }
}
function buttonDown() {
  gpioState[3 /* BUTTON */] = GPIO_PIN_LOW;
  addLog2("Button pressed", "debug-low");
}
function buttonUp() {
  gpioState[3 /* BUTTON */] = GPIO_PIN_HIGH;
  addLog2("Button released", "debug-low");
}
function toggleSoil() {
  state.soilDry = !state.soilDry;
  gpioState[1 /* SOIL_SENSOR */] = state.soilDry ? GPIO_PIN_HIGH : GPIO_PIN_LOW;
  addLog2(`Soil sensor: ${state.soilDry ? "DRY" : "WET"}`, "info");
}

// graph.ts
var SIGNALS = ["button", "pump", "soil", "display"];
var CANVAS_IDS = {
  button: "buttonGraph",
  pump: "pumpGraph",
  soil: "soilGraph",
  display: "clockGraph"
};
var COLORS_SOLID = {
  button: "rgb(155, 89, 182)",
  pump: "rgb(231, 76, 60)",
  soil: "rgb(52, 152, 219)",
  display: "rgb(243, 156, 18)"
};
var canvases = {};
var contexts = {};
var timeAxisCanvas = null;
var timeAxisCtx = null;
var graphData = {
  button: [],
  pump: [],
  soil: [],
  display: []
};
var scrollOffset = 0;
var autoScroll = true;
var maxTime = 0;
var isDragging = false;
var dragStartX = 0;
var dragStartOffset = 0;
function initGraph() {
  SIGNALS.forEach((sig) => {
    const canvas = document.getElementById(CANVAS_IDS[sig]);
    if (canvas) {
      canvases[sig] = canvas;
      const ctx = canvas.getContext("2d");
      if (ctx) {
        contexts[sig] = ctx;
      }
      canvas.addEventListener("wheel", (e) => handleZoom(e, canvas), { passive: false });
      canvas.addEventListener("mousedown", handleDragStart);
      canvas.addEventListener("mousemove", handleDragMove);
      canvas.addEventListener("mouseup", handleDragEnd);
      canvas.addEventListener("mouseleave", handleDragEnd);
    }
  });
  timeAxisCanvas = document.getElementById("timeAxisCanvas");
  if (timeAxisCanvas) {
    timeAxisCtx = timeAxisCanvas.getContext("2d");
  }
  document.getElementById("btnScrollStart")?.addEventListener("click", scrollToStart);
  document.getElementById("btnScrollLeft")?.addEventListener("click", () => scrollBy(getTimeWindow() * 0.25));
  document.getElementById("btnScrollRight")?.addEventListener("click", () => scrollBy(-getTimeWindow() * 0.25));
  document.getElementById("btnScrollEnd")?.addEventListener("click", scrollToEnd);
  document.getElementById("btnClearGraph")?.addEventListener("click", clearGraph);
  const autoScrollCheckbox = document.getElementById("chkAutoScroll");
  autoScrollCheckbox?.addEventListener("change", (e) => {
    const target = e.target;
    autoScroll = target.checked;
    if (autoScroll) {
      scrollOffset = 0;
      drawGraph();
    }
  });
  document.getElementById("graphTimeWindow")?.addEventListener("change", () => {
    clampScrollOffset();
    drawGraph();
  });
  document.addEventListener("keydown", handleKeyboard);
  window.addEventListener("resize", resizeGraph);
  resizeGraph();
}
function handleDragStart(event) {
  isDragging = true;
  dragStartX = event.clientX;
  dragStartOffset = scrollOffset;
  event.target.style.cursor = "grabbing";
}
function handleDragMove(event) {
  if (!isDragging) return;
  const canvas = event.target;
  const dx = event.clientX - dragStartX;
  const timeWindow = getTimeWindow();
  const pixelsPerSecond = canvas.width / timeWindow;
  const timeDelta = dx / pixelsPerSecond;
  autoScroll = false;
  updateAutoScrollCheckbox();
  scrollOffset = dragStartOffset + timeDelta;
  clampScrollOffset();
  drawGraph();
}
function handleDragEnd(event) {
  if (isDragging) {
    isDragging = false;
    event.target.style.cursor = "grab";
  }
}
function handleKeyboard(event) {
  const target = event.target;
  if (target.tagName === "INPUT" || target.tagName === "TEXTAREA" || target.tagName === "SELECT") {
    return;
  }
  const timeWindow = getTimeWindow();
  switch (event.key) {
    case "ArrowLeft":
      scrollBy(event.shiftKey ? timeWindow * 0.5 : timeWindow * 0.1);
      event.preventDefault();
      break;
    case "ArrowRight":
      scrollBy(event.shiftKey ? -timeWindow * 0.5 : -timeWindow * 0.1);
      event.preventDefault();
      break;
    case "Home":
      scrollToStart();
      event.preventDefault();
      break;
    case "End":
      scrollToEnd();
      event.preventDefault();
      break;
  }
}
function scrollBy(amount) {
  autoScroll = false;
  updateAutoScrollCheckbox();
  scrollOffset += amount;
  clampScrollOffset();
  drawGraph();
}
function scrollToStart() {
  autoScroll = false;
  updateAutoScrollCheckbox();
  const timeWindow = getTimeWindow();
  scrollOffset = Math.max(0, maxTime - timeWindow);
  drawGraph();
}
function scrollToEnd() {
  autoScroll = true;
  updateAutoScrollCheckbox();
  scrollOffset = 0;
  drawGraph();
}
function updateAutoScrollCheckbox() {
  const checkbox = document.getElementById("chkAutoScroll");
  if (checkbox) {
    checkbox.checked = autoScroll;
  }
}
function clampScrollOffset() {
  const timeWindow = getTimeWindow();
  const maxOffset = Math.max(0, maxTime - timeWindow);
  scrollOffset = Math.max(0, Math.min(scrollOffset, maxOffset));
}
function getTimeWindow() {
  const dropdown = document.getElementById("graphTimeWindow");
  if (!dropdown) return 60;
  if (dropdown.value === "custom") {
    const customValue = dropdown.selectedOptions[0]?.dataset.customValue;
    return customValue ? parseFloat(customValue) : 60;
  }
  return parseFloat(dropdown.value || "60");
}
function formatTime(seconds) {
  if (seconds >= 3600) {
    const h = Math.floor(seconds / 3600);
    const m = Math.floor(seconds % 3600 / 60);
    const s = Math.floor(seconds % 60);
    return `${h}:${m.toString().padStart(2, "0")}:${s.toString().padStart(2, "0")}`;
  } else if (seconds >= 60) {
    const m = Math.floor(seconds / 60);
    const s = (seconds % 60).toFixed(1);
    return `${m}:${parseFloat(s).toFixed(1).padStart(4, "0")}`;
  }
  return `${seconds.toFixed(2)}s`;
}
function updateScrollPositionDisplay(startTime, endTime) {
  const display = document.getElementById("scrollPosition");
  if (display) {
    if (maxTime === 0) {
      display.textContent = "No data";
    } else {
      display.textContent = `${formatTime(startTime)} \u2014 ${formatTime(endTime)} | Total: ${formatTime(maxTime)}`;
    }
  }
}
function resizeGraph() {
  SIGNALS.forEach((sig) => {
    const canvas = canvases[sig];
    if (!canvas) return;
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width;
    canvas.height = rect.height;
  });
  if (timeAxisCanvas) {
    const rect = timeAxisCanvas.getBoundingClientRect();
    timeAxisCanvas.width = rect.width;
    timeAxisCanvas.height = rect.height;
  }
  drawGraph();
}
function addGraphDataFromGPIO(gpioSnapshot, timestamp) {
  graphData.display.push({ time: timestamp, value: gpioSnapshot[0 /* DISPLAY */] });
  graphData.soil.push({ time: timestamp, value: gpioSnapshot[1 /* SOIL_SENSOR */] });
  graphData.pump.push({ time: timestamp, value: gpioSnapshot[2 /* PUMP */] });
  graphData.button.push({ time: timestamp, value: gpioSnapshot[3 /* BUTTON */] });
  maxTime = Math.max(maxTime, timestamp);
  if (autoScroll) {
    scrollOffset = 0;
  }
  drawGraph();
}
function getVisibleRange() {
  const timeWindow = getTimeWindow();
  let endTime;
  let startTime;
  if (maxTime === 0) {
    return { startTime: 0, endTime: timeWindow, timeWindow };
  }
  if (autoScroll) {
    endTime = Math.max(timeWindow, maxTime);
    startTime = endTime - timeWindow;
  } else {
    endTime = Math.max(timeWindow, maxTime - scrollOffset);
    startTime = endTime - timeWindow;
    if (startTime < 0) {
      startTime = 0;
      endTime = timeWindow;
    }
  }
  return { startTime, endTime, timeWindow };
}
function drawGraph() {
  const { startTime, endTime, timeWindow } = getVisibleRange();
  updateScrollPositionDisplay(startTime, endTime);
  SIGNALS.forEach((sig) => {
    const ctx = contexts[sig];
    const canvas = canvases[sig];
    if (!ctx || !canvas) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    drawSignalGrid(ctx, canvas, startTime, timeWindow);
    const data = graphData[sig];
    if (data.length === 0) return;
    const dataStartTime = data[0].time;
    const dataEndTime = data[data.length - 1].time;
    if (endTime < dataStartTime) return;
    if (startTime > dataEndTime) {
      const lastPoint = data[data.length - 1];
      const highY2 = 8;
      const lowY2 = canvas.height - 8;
      const y = lastPoint.value ? highY2 : lowY2;
      ctx.strokeStyle = COLORS_SOLID[sig];
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(canvas.width, y);
      ctx.stroke();
      return;
    }
    const visibleData = data.filter((p) => p.time >= startTime && p.time <= endTime);
    let pointBeforeWindow = null;
    for (let i = data.length - 1; i >= 0; i--) {
      if (data[i].time < startTime) {
        pointBeforeWindow = data[i];
        break;
      }
    }
    let pointAfterWindow = null;
    for (let i = 0; i < data.length; i++) {
      if (data[i].time > endTime) {
        pointAfterWindow = data[i];
        break;
      }
    }
    ctx.strokeStyle = COLORS_SOLID[sig];
    ctx.lineWidth = 2;
    ctx.beginPath();
    const highY = 8;
    const lowY = canvas.height - 8;
    let lastY = null;
    let lastX = null;
    let started = false;
    if (pointBeforeWindow !== null) {
      lastY = pointBeforeWindow.value ? highY : lowY;
      ctx.moveTo(0, lastY);
      started = true;
    }
    visibleData.forEach((point) => {
      const x = (point.time - startTime) / timeWindow * canvas.width;
      const y = point.value ? highY : lowY;
      if (!started) {
        ctx.moveTo(x, y);
        started = true;
      } else {
        ctx.lineTo(x, lastY);
        ctx.lineTo(x, y);
      }
      lastX = x;
      lastY = y;
    });
    if (started && lastY !== null && pointAfterWindow !== null) {
      ctx.lineTo(canvas.width, lastY);
    }
    ctx.stroke();
  });
  drawTimeAxis(startTime, timeWindow);
}
function drawSignalGrid(ctx, canvas, startTime, timeWindow) {
  ctx.strokeStyle = "rgba(0, 0, 0, 0.06)";
  ctx.lineWidth = 1;
  let gridInterval;
  if (timeWindow <= 10) gridInterval = 1;
  else if (timeWindow <= 30) gridInterval = 5;
  else if (timeWindow <= 60) gridInterval = 10;
  else if (timeWindow <= 300) gridInterval = 30;
  else if (timeWindow <= 600) gridInterval = 60;
  else gridInterval = 300;
  const firstGrid = Math.ceil(startTime / gridInterval) * gridInterval;
  for (let t = firstGrid; t <= startTime + timeWindow; t += gridInterval) {
    const x = (t - startTime) / timeWindow * canvas.width;
    ctx.beginPath();
    ctx.moveTo(x, 0);
    ctx.lineTo(x, canvas.height);
    ctx.stroke();
  }
}
function drawTimeAxis(startTime, timeWindow) {
  if (!timeAxisCtx || !timeAxisCanvas) return;
  const ctx = timeAxisCtx;
  const canvas = timeAxisCanvas;
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  ctx.fillStyle = "#333";
  ctx.font = "10px system-ui, -apple-system, sans-serif";
  ctx.textAlign = "center";
  let labelInterval;
  if (timeWindow <= 10) labelInterval = 1;
  else if (timeWindow <= 30) labelInterval = 5;
  else if (timeWindow <= 60) labelInterval = 10;
  else if (timeWindow <= 300) labelInterval = 30;
  else if (timeWindow <= 600) labelInterval = 60;
  else labelInterval = 300;
  const firstLabel = Math.ceil(startTime / labelInterval) * labelInterval;
  for (let t = firstLabel; t <= startTime + timeWindow; t += labelInterval) {
    const x = (t - startTime) / timeWindow * canvas.width;
    ctx.strokeStyle = "#999";
    ctx.beginPath();
    ctx.moveTo(x, 0);
    ctx.lineTo(x, 4);
    ctx.stroke();
    let label;
    if (t >= 3600) {
      const h = Math.floor(t / 3600);
      const m = Math.floor(t % 3600 / 60);
      label = `${h}h${m > 0 ? m + "m" : ""}`;
    } else if (t >= 60) {
      const m = Math.floor(t / 60);
      const s = t % 60;
      label = s === 0 ? `${m}m` : `${m}:${s.toString().padStart(2, "0")}`;
    } else {
      label = `${t}s`;
    }
    ctx.fillText(label, x, 16);
  }
}
function clearGraph() {
  SIGNALS.forEach((sig) => {
    graphData[sig] = [];
  });
  scrollOffset = 0;
  autoScroll = true;
  maxTime = 0;
  updateAutoScrollCheckbox();
  drawGraph();
}
function handleZoom(event, canvas) {
  event.preventDefault();
  const rect = canvas.getBoundingClientRect();
  const mouseX = event.clientX - rect.left;
  const mouseXRatio = mouseX / canvas.width;
  const timeWindow = getTimeWindow();
  const { startTime, endTime } = getVisibleRange();
  const mouseTime = startTime + (endTime - startTime) * mouseXRatio;
  const zoomFactor = event.deltaY < 0 ? 1.1 : 0.9;
  const newTimeWindow = Math.max(0.1, Math.min(3600, timeWindow * zoomFactor));
  const newStartTime = mouseTime - (mouseTime - startTime) * (newTimeWindow / timeWindow);
  autoScroll = false;
  updateAutoScrollCheckbox();
  scrollOffset = Math.max(0, maxTime - newStartTime - newTimeWindow);
  setTimeWindow(newTimeWindow);
  drawGraph();
}
function setTimeWindow(seconds) {
  const dropdown = document.getElementById("graphTimeWindow");
  if (!dropdown) return;
  const exactMatch = Array.from(dropdown.options).find(
    (opt) => Math.abs(parseFloat(opt.value) - seconds) < 0.01
  );
  if (exactMatch) {
    dropdown.value = exactMatch.value;
  } else {
    let customOption = Array.from(dropdown.options).find((opt) => opt.value === "custom");
    if (!customOption) {
      customOption = document.createElement("option");
      customOption.value = "custom";
      dropdown.appendChild(customOption);
    }
    customOption.text = `Custom (${formatTime(seconds)})`;
    customOption.dataset.customValue = seconds.toString();
    dropdown.value = "custom";
  }
}
function fitToScreen() {
  if (maxTime === 0) {
    addLog("No data to fit", "warning");
    return;
  }
  const paddedTime = maxTime * 1.05;
  setTimeWindow(paddedTime);
  autoScroll = false;
  scrollOffset = 0;
  updateAutoScrollCheckbox();
  drawGraph();
  addLog(`Fitted ${formatTime(maxTime)} to screen`, "debug-high");
}
function zoomIn() {
  const currentWindow = getTimeWindow();
  const newWindow = Math.max(0.1, currentWindow / 2);
  setTimeWindow(newWindow);
  autoScroll = false;
  updateAutoScrollCheckbox();
  clampScrollOffset();
  drawGraph();
}
function zoomOut() {
  const currentWindow = getTimeWindow();
  const newWindow = Math.min(7200, currentWindow * 2);
  setTimeWindow(newWindow);
  autoScroll = false;
  updateAutoScrollCheckbox();
  clampScrollOffset();
  drawGraph();
}
document.getElementById("btnFitToScreen")?.addEventListener("click", fitToScreen);
document.getElementById("btnZoomIn")?.addEventListener("click", zoomIn);
document.getElementById("btnZoomOut")?.addEventListener("click", zoomOut);

// simulation.ts
var TICK_DURATION_SECONDS2 = 0.02;
var BASE_INTERVAL_MS = 20;
var TICKS_PER_MINUTE = 3e3;
var TICKS_PER_HOUR = 18e4;
var FAST_FORWARD_GRAPH_INTERVAL = 100;
var DEFAULT_SPEED = 1;
var DOM_IDS2 = {
  START_STOP_BUTTON: "btnStartStop",
  SPEED_SLIDER: "speedSlider",
  SPEED_DISPLAY: "speedDisplay"
};
function getElement2(id) {
  return document.getElementById(id);
}
function getCurrentSpeed() {
  const slider = getElement2(DOM_IDS2.SPEED_SLIDER);
  return slider ? parseInt(slider.value, 10) || DEFAULT_SPEED : DEFAULT_SPEED;
}
function updateStartStopButton() {
  const button = getElement2(DOM_IDS2.START_STOP_BUTTON);
  if (button) {
    button.textContent = state.isRunning ? "Stop" : "Start";
    button.classList.toggle("running", state.isRunning);
  }
}
function updateSpeedDisplay(speed) {
  const display = getElement2(DOM_IDS2.SPEED_DISPLAY);
  if (display) {
    display.textContent = `${speed}x`;
  }
}
function clearSimulationInterval() {
  if (state.intervalId !== null) {
    clearInterval(state.intervalId);
    state.intervalId = null;
  }
}
function recordGraphData() {
  const timestamp = state.tickCount * TICK_DURATION_SECONDS2;
  addGraphDataFromGPIO({ ...gpioState }, timestamp);
}
function isModuleReady() {
  return state.Module !== null;
}
function tick() {
  if (!state.Module) {
    return;
  }
  state.Module._main();
  state.tickCount++;
  updateStatus();
  recordGraphData();
}
function startSimulation() {
  if (state.isRunning) {
    return;
  }
  if (!isModuleReady()) {
    addLog2("Cannot start: Module not loaded", "error");
    return;
  }
  state.isRunning = true;
  updateStartStopButton();
  updateSpeed();
  addLog2("Simulation started", "info");
}
function stopSimulation() {
  if (!state.isRunning) {
    return;
  }
  state.isRunning = false;
  clearSimulationInterval();
  updateStartStopButton();
  addLog2("Simulation stopped", "info");
}
function toggleSimulation() {
  if (state.isRunning) {
    stopSimulation();
  } else {
    startSimulation();
  }
}
function updateSpeed() {
  clearSimulationInterval();
  const speed = getCurrentSpeed();
  const interval = BASE_INTERVAL_MS / speed;
  updateSpeedDisplay(speed);
  if (state.isRunning) {
    state.intervalId = window.setInterval(tick, interval);
  }
}
function singleStep() {
  if (!isModuleReady()) {
    addLog2("Module not loaded", "error");
    return;
  }
  tick();
  addLog2(`Single step executed (tick ${state.tickCount.toLocaleString()})`, "debug-high");
}
var fastForwardInProgress = false;
function fastForward(totalTicks, graphInterval, description) {
  if (!state.Module) {
    addLog2("Module not loaded", "error");
    return;
  }
  if (fastForwardInProgress) {
    addLog2("Fast-forward already in progress", "warning");
    return;
  }
  fastForwardInProgress = true;
  addLog2(`Running ${description} (${totalTicks.toLocaleString()} ticks)...`, "info");
  const startTime = performance.now();
  try {
    for (let i = 0; i < totalTicks; i++) {
      state.Module._main();
      state.tickCount++;
      if (i % graphInterval === 0) {
        recordGraphData();
      }
    }
    recordGraphData();
    updateStatus();
    const elapsed = ((performance.now() - startTime) / 1e3).toFixed(2);
    addLog2(`${description} completed in ${elapsed}s`, "info");
  } catch (error) {
    const message = error instanceof Error ? error.message : String(error);
    addLog2(`Fast-forward error: ${message}`, "error");
    console.error("[FAST-FORWARD] Error:", error);
  } finally {
    fastForwardInProgress = false;
  }
}
function runMinute() {
  fastForward(TICKS_PER_MINUTE, 1, "1 minute");
}
function runHour() {
  fastForward(TICKS_PER_HOUR, FAST_FORWARD_GRAPH_INTERVAL, "1 hour");
}

// app.ts
function exposeGlobalFunctions() {
  window._gpioState = gpioState;
  window.getGPIOState = getGPIOState;
  window.setGPIOState = setGPIOState;
  window.buttonDown = buttonDown;
  window.buttonUp = buttonUp;
  window.toggleSoil = toggleSoil;
  window.startSimulation = startSimulation;
  window.stopSimulation = stopSimulation;
  window.toggleSimulation = toggleSimulation;
  window.singleStep = singleStep;
  window.runMinute = runMinute;
  window.runHour = runHour;
  window.clearGraph = clearGraph;
  window.clearLog = clearLog;
}
async function loadModule() {
  if (typeof window.createPlantWateringModule !== "function") {
    const error = new Error(
      "createPlantWateringModule not found. Ensure plant-watering.js is loaded before app.js"
    );
    addLog2(error.message, "error");
    throw error;
  }
  try {
    const module = await window.createPlantWateringModule();
    state.Module = module;
    window.Module = module;
    addLog2("Module loaded successfully", "info");
    console.log("[DEBUG] Before first _main(), gpioState:", { ...gpioState });
    module._main();
    console.log("[DEBUG] After first _main(), gpioState:", { ...gpioState });
    console.log("[DEBUG] Display pin (0):", gpioState[0]);
    addGraphDataFromGPIO({ ...gpioState }, 0);
    state.tickCount = 1;
    addLog2("Module loaded successfully", "info");
  } catch (error) {
    const message = error instanceof Error ? error.message : String(error);
    addLog2(`Failed to load module: ${message}`, "error");
    throw error;
  }
}
function setupEventListeners() {
  const speedSlider = document.getElementById("speedSlider");
  if (speedSlider) {
    speedSlider.addEventListener("input", updateSpeed);
  }
}
async function init() {
  console.log("[APP] Initializing Plant Watering Simulator");
  exposeGlobalFunctions();
  initGraph();
  setupEventListeners();
  try {
    await loadModule();
    console.log("[APP] Initialization complete");
  } catch (error) {
    console.error("[APP] Initialization failed:", error);
  }
}
window.addEventListener("load", init);
export {
  init,
  loadModule
};
